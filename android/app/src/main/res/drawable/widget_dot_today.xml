<?xml version="1.0" encoding="utf-8"?>
<!-- Outlined ring — used for the "this day is today" cube in the week
     widget. The stroke-only fill distinguishes today from regular days
     (gray fill) and override days (yellow fill) without stealing colour
     budget from the accent strip or the cube tint. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@android:color/transparent" />
    <stroke android:width="1.5dp" android:color="#FFFFFF" />
    <size android:width="10dp" android:height="10dp" />
</shape>
