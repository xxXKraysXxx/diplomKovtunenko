<?xml version="1.0" encoding="utf-8"?>
<!--
    Current-lesson widget. Rows use weighted heights so visible rows spread
    across the full available height at every size bucket:
      3×1: only `now_row` visible → fills the widget vertically.
      3×2: `prev_row` + `now_row` + `next_row` visible → each gets ~1/3.
      3×3: all four rows visible → each gets ~1/4.
    GONE rows don't consume weight, so LinearLayout redistributes space to
    the visible ones. Inner rows use gravity="center_vertical" so text sits
    in the middle of its weighted slice instead of clustering at the top.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_current_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background_light"
    android:padding="10dp">

    <!-- Row: previous lesson. Only shown in medium (3x2) / large (3x3). -->
    <LinearLayout
        android:id="@+id/widget_current_prev_row"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView
            android:id="@+id/widget_current_prev_accent"
            android:layout_width="3dp"
            android:layout_height="20dp"
            android:background="@drawable/widget_accent_strip"
            android:layout_marginEnd="8dp"
            android:alpha="0.45"
            android:contentDescription="@null" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_current_prev_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="10sp"
                android:textColor="#94A3B8"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/widget_current_prev_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row: current (or "next if nothing current") lesson — always visible. -->
    <LinearLayout
        android:id="@+id/widget_current_now_row"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:id="@+id/widget_current_accent"
            android:layout_width="4dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_accent_strip"
            android:layout_marginEnd="10dp"
            android:contentDescription="@null" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_current_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/widget_current_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:paddingTop="2dp"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row: next lesson — compact footer. Visible in medium/large. -->
    <LinearLayout
        android:id="@+id/widget_current_next_row"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <TextView
            android:id="@+id/widget_current_next_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="10sp"
            android:textColor="#64748B"
            android:paddingEnd="6dp"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/widget_current_next_detail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textColor="#64748B"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Row: after-next lesson — compact footer. Only shown in large (3x3). -->
    <LinearLayout
        android:id="@+id/widget_current_after_next_row"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <TextView
            android:id="@+id/widget_current_after_next_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="10sp"
            android:textColor="#94A3B8"
            android:paddingEnd="6dp"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/widget_current_after_next_detail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textColor="#94A3B8"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
